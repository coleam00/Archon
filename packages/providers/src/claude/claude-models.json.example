{
  "providers": {
    "gateway": {
      "baseUrl": "https://llm-gateway.example.com",
      "apiKey": "CLAUDE_GATEWAY_API_KEY",
      "headers": {
        "X-Team": "platform",
        "X-Workspace-Token": "CLAUDE_GATEWAY_WORKSPACE_TOKEN"
      },
      "models": [
        {
          "id": "openai/gpt-5.4",
          "name": "gpt",
          "reasoning": true
        },
        {
          "id": "zai-org/glm-5",
          "name": "glm",
          "reasoning": false
        }
      ]
    },
    "local": {
      "baseUrl": "http://localhost:4000",
      "authToken": "CLAUDE_LOCAL_GATEWAY_TOKEN",
      "models": [
        {
          "id": "local/model-name",
          "name": "local-model"
        }
      ]
    }
  }
}
