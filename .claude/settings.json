{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(python3 ~/.kiro/scripts/*:*)",
      "Bash(python3 ~/.kiro/skills/*:*)",
      "Bash(gitleaks:*)",
      "Bash(semgrep:*)",
      "Bash(trivy:*)",
      "Bash(checkov:*)",
      "Bash(ruff:*)",
      "Bash(pyright:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/skills/save-task-list/hooks/verify-task-list.sh",
            "statusMessage": "Checking for restored task list..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.kiro/claude-code/hooks/session-register.sh",
            "statusMessage": "Registering GDIT session..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "kild agent-status --self working 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.kiro/claude-code/hooks/validate-on-edit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "kild agent-status --self idle 2>/dev/null || true",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.kiro/claude-code/hooks/checkpoint-reminder.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "rulecheck-agent",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/skills/rulecheck/hooks/slack-notify.sh",
            "statusMessage": "Notifying Slack..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "kild agent-status --self waiting 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
