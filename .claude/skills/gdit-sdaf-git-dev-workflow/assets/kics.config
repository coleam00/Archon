# KICS Configuration
# Infrastructure as Code security scanning

# Exclude paths
exclude-paths:
  - node_modules/**
  - .git/**
  - dist/**
  - build/**
  - .terraform/**

# Exclude queries (with justification)
# exclude-queries:
#   - query-id  # Reason: Not applicable

# Include queries (specific checks to run)
# include-queries:
#   - query-id

# Exclude severities
# exclude-severities:
#   - INFO
#   - LOW

# Exclude categories
# exclude-categories:
#   - Best Practices

# Output format
type:
  - json
  - sarif

# Fail on severity
fail-on:
  - high
  - critical

# Platforms to scan
platform:
  - CloudFormation
  - Terraform
  - Kubernetes
  - Docker
  - Ansible

# Disable full descriptions
minimal-ui: true

# Verbose output
verbose: false

# Timeout per file (seconds)
timeout: 60
