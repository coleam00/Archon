# HCOM Infrastructure Compliance Rules
# CFN-Guard Policy-as-Code for NIST 800-171 and FedRAMP Compliance
# 
# Usage:
#   cfn-guard validate --data <template.yml> --rules assets/cfn-guard-rules.guard
#
# References:
#   - NIST 800-171 Rev 2: https://csrc.nist.gov/publications/detail/sp/800-171/rev-2/final
#   - FedRAMP Security Controls: https://www.fedramp.gov/assets/resources/documents/FedRAMP_Security_Controls_Baseline.xlsx

#
# RULE 1: Lambda functions must have IAM roles
# Compliance: NIST 800-171 3.1.5 (Least Privilege), FedRAMP AC-6
#
let lambda_functions = Resources.*[ Type == 'AWS::Lambda::Function' ]

rule lambda_has_iam_role when %lambda_functions !empty {
  %lambda_functions {
    Properties.Role exists
    <<Lambda function must have an IAM role defined (NIST 800-171 3.1.5)>>
  }
}

#
# RULE 2: S3 buckets must have encryption enabled
# Compliance: NIST 800-171 3.13.11 (Encryption at Rest), FedRAMP SC-28
#
let s3_buckets = Resources.*[ Type == 'AWS::S3::Bucket' ]

rule s3_bucket_encryption when %s3_buckets !empty {
  %s3_buckets {
    Properties.BucketEncryption exists
    Properties.BucketEncryption.ServerSideEncryptionConfiguration exists
    <<S3 bucket must have encryption enabled (NIST 800-171 3.13.11)>>
  }
}

#
# RULE 3: S3 buckets must block public access
# Compliance: NIST 800-171 3.1.3 (Access Control), FedRAMP AC-3
#
rule s3_bucket_public_access_block when %s3_buckets !empty {
  %s3_buckets {
    Properties.PublicAccessBlockConfiguration exists
    Properties.PublicAccessBlockConfiguration.BlockPublicAcls == true
    Properties.PublicAccessBlockConfiguration.BlockPublicPolicy == true
    Properties.PublicAccessBlockConfiguration.IgnorePublicAcls == true
    Properties.PublicAccessBlockConfiguration.RestrictPublicBuckets == true
    <<S3 bucket must block all public access (NIST 800-171 3.1.3)>>
  }
}

#
# RULE 4: DynamoDB tables must have encryption enabled
# Compliance: NIST 800-171 3.13.11 (Encryption at Rest), FedRAMP SC-28
#
let dynamodb_tables = Resources.*[ Type == 'AWS::DynamoDB::Table' ]

rule dynamodb_encryption when %dynamodb_tables !empty {
  %dynamodb_tables {
    Properties.SSESpecification exists
    Properties.SSESpecification.SSEEnabled == true
    <<DynamoDB table must have encryption enabled (NIST 800-171 3.13.11)>>
  }
}

#
# RULE 5: SNS topics must have encryption enabled
# Compliance: NIST 800-171 3.13.11 (Encryption at Rest), FedRAMP SC-28
#
let sns_topics = Resources.*[ Type == 'AWS::SNS::Topic' ]

rule sns_encryption when %sns_topics !empty {
  %sns_topics {
    Properties.KmsMasterKeyId exists
    <<SNS topic must have KMS encryption enabled (NIST 800-171 3.13.11)>>
  }
}

#
# RULE 6: SQS queues must have encryption enabled
# Compliance: NIST 800-171 3.13.11 (Encryption at Rest), FedRAMP SC-28
#
let sqs_queues = Resources.*[ Type == 'AWS::SQS::Queue' ]

rule sqs_encryption when %sqs_queues !empty {
  %sqs_queues {
    Properties.KmsMasterKeyId exists
    <<SQS queue must have KMS encryption enabled (NIST 800-171 3.13.11)>>
  }
}

#
# RULE 7: Lambda functions must have DLQ configured
# Compliance: NIST 800-171 3.3.4 (Error Handling), FedRAMP SI-11
#
rule lambda_has_dlq when %lambda_functions !empty {
  %lambda_functions {
    Properties.DeadLetterConfig exists
    Properties.DeadLetterConfig.TargetArn exists
    <<Lambda function must have Dead Letter Queue configured (NIST 800-171 3.3.4)>>
  }
}

#
# RULE 8: Lambda functions must have reserved concurrency
# Compliance: NIST 800-171 3.4.2 (Resource Availability), FedRAMP SC-6
#
rule lambda_has_reserved_concurrency when %lambda_functions !empty {
  %lambda_functions {
    Properties.ReservedConcurrentExecutions exists
    <<Lambda function must have reserved concurrency to prevent resource exhaustion (NIST 800-171 3.4.2)>>
  }
}

#
# RULE 9: IAM roles must not use wildcard in actions
# Compliance: NIST 800-171 3.1.5 (Least Privilege), FedRAMP AC-6
#
let iam_roles = Resources.*[ Type == 'AWS::IAM::Role' ]

rule iam_no_wildcard_actions when %iam_roles !empty {
  %iam_roles {
    Properties.Policies[*].PolicyDocument.Statement[*] {
      when Action exists {
        Action != '*'
        <<IAM policy must not use wildcard (*) in Action (NIST 800-171 3.1.5)>>
      }
    }
  }
}

#
# RULE 10: IAM roles should minimize wildcard resource usage
# Compliance: NIST 800-171 3.1.5 (Least Privilege), FedRAMP AC-6
# NOTE: This is advisory - wildcards are acceptable for read-only operations
#       like logs:DescribeLogGroups, securityhub:GetFindings
# ENFORCEMENT: Manual review during code review
#
